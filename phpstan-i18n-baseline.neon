# i18n PHPStan baseline — residual deferred work
#
# Remaining entries are deferred to future phases:
#   - Notifications + mail templates → Phase 2
#   - BaseLivewireComponent, CallbackController, NotifyTaskAssignees → opportunistic cleanup
#
# MCP Tools and ImportWizard are excluded via phpstan.neon path-level ignores (Phase 4).
# When this file is empty, delete it and remove the include from phpstan.neon.

parameters:
	ignoreErrors:
		-
			message: '#^Hardcoded user\-facing string in \-\>label\(\) — wrap in __\(\) and add a key under lang/en/\.$#'
			identifier: app.i18n.hardcodedUserFacingString
			count: 1
			path: app/Actions/Task/NotifyTaskAssignees.php

		-
			message: '#^Hardcoded user\-facing string in \-\>title\(\) — wrap in __\(\) and add a key under lang/en/\.$#'
			identifier: app.i18n.hardcodedUserFacingString
			count: 1
			path: app/Http/Controllers/Auth/CallbackController.php

		-
			message: '#^Hardcoded user\-facing string in \-\>title\(\) — wrap in __\(\) and add a key under lang/en/\.$#'
			identifier: app.i18n.hardcodedUserFacingString
			count: 1
			path: app/Livewire/BaseLivewireComponent.php

		-
			message: '#^Hardcoded user\-facing string in \-\>subject\(\) — wrap in __\(\) and add a key under lang/en/\.$#'
			identifier: app.i18n.hardcodedUserFacingString
			count: 1
			path: app/Notifications/UserDeletionCancelledNotification.php

		-
			message: '#^Hardcoded user\-facing string in \-\>subject\(\) — wrap in __\(\) and add a key under lang/en/\.$#'
			identifier: app.i18n.hardcodedUserFacingString
			count: 1
			path: app/Notifications/UserDeletionScheduledNotification.php
